# Copy this file to .env and fill in your values
# Never commit .env to git

# Example:
#OKTA_ORG_URL=https://your-okta-org.okta.com
#OKTA_API_TOKEN=your-api-token-here
#SLACK_WEBHOOK_EVENTS=https://hooks.slack.com/services/... (optional, posts to #okta-events)
#SLACK_WEBHOOK_ERRORS=https://hooks.slack.com/services/... (optional, posts to #okta-errors)
